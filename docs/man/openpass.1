.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass - OpenPass is a Go CLI password manager


.SH SYNOPSIS
\fBopenpass [flags]\fP


.SH DESCRIPTION
OpenPass is a Go CLI password manager


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for openpass

.PP
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


