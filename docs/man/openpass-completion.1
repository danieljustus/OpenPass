.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass-completion - Generate the autocompletion script for the specified shell


.SH SYNOPSIS
\fBopenpass completion [flags]\fP


.SH DESCRIPTION
Generate the autocompletion script for openpass for the specified shell.
See each sub-command's help for details on how to use the generated script.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP, \fBopenpass-completion-bash(1)\fP, \fBopenpass-completion-fish(1)\fP, \fBopenpass-completion-powershell(1)\fP, \fBopenpass-completion-zsh(1)\fP
