.nh
.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass-diag-metrics - Print current metric values for debugging


.SH SYNOPSIS
\fBopenpass diag metrics [flags]\fP


.SH DESCRIPTION
Print current metric values for debugging


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for metrics


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass-diag(1)\fP
