.nh
.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass-auth - Manage vault unlock authentication


.SH SYNOPSIS
\fBopenpass auth [flags]\fP


.SH DESCRIPTION
Manage vault unlock authentication


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for auth


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--profile\fP=""
	use a named vault profile

.PP
\fB--quiet\fP[=false]
	suppress non-error output

.PP
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP, \fBopenpass-auth-set(1)\fP, \fBopenpass-auth-status(1)\fP
