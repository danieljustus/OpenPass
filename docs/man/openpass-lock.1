.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass-lock - Lock the vault (clear session)


.SH SYNOPSIS
\fBopenpass lock [flags]\fP


.SH DESCRIPTION
Lock the vault (clear session)


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for lock


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP
