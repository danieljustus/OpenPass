.TH "OPENPASS" "1" "Apr 2026" "OpenPass" "OpenPass Manual"

.SH NAME
openpass-find - Search for entries


.SH SYNOPSIS
\fBopenpass find  [flags]\fP


.SH DESCRIPTION
Searches entry paths and contents for the given query.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for find

.PP
\fB-j\fP, \fB--json\fP[=false]
	Output as JSON


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--vault\fP="~/.openpass"
	path to the password vault


.SH SEE ALSO
\fBopenpass(1)\fP
